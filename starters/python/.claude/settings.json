{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/block-secrets.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/format-on-write.sh" }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(ruff format:*)",
      "Bash(ruff check:*)",
      "Bash(mypy:*)",
      "Bash(pyright:*)",
      "Bash(pytest:*)",
      "Bash(python -m pytest:*)",
      "Bash(uvicorn:*)",
      "Bash(python manage.py:*)",
      "Bash(alembic:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Write"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(rm -rf:*)",
      "Bash(pip install:*)",
      "Bash(poetry add:*)",
      "Bash(uv add:*)"
    ]
  }
}
